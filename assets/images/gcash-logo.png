<?php
// Create a simple GCash logo using GD library
$width = 80;
$height = 80;
$image = imagecreatetruecolor($width, $height);

// GCash colors
$blue = imagecolorallocate($image, 0, 102, 204); // #0066cc
$white = imagecolorallocate($image, 255, 255, 255);
$gray = imagecolorallocate($image, 240, 240, 240);

// Create rounded rectangle background
imagefilledrectangle($image, 0, 0, $width, $height, $blue);

// Add "GC" text in white
$font_size = 20;
$text = "GC";
$x = ($width - imagefontwidth($font_size) * strlen($text)) / 2;
$y = ($height - imagefontheight($font_size)) / 2;

// Use built-in font
imagestring($image, 5, $x + 10, $y + 25, $text, $white);

// Output the image
header('Content-Type: image/png');
imagepng($image);
imagedestroy($image);
?>
